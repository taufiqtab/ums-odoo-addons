<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_ums" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.ums</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="UMS" string="UMS" name="ums_auth">
                    <block title="UMS Authentication" name="ums_setting_container">
                        <setting id="ums_base_url_setting" string="UMS Base URL" help="Base URL of the UMS server">
                            <field name="ums_base_url" placeholder="https://ums.yourserver.com"/>
                        </setting>
                        <setting id="ums_app_id_setting" string="UMS App ID" help="Application ID registered in UMS">
                            <field name="ums_app_id" placeholder="odoo-app"/>
                        </setting>
                        <setting id="ums_callback_url_setting" string="UMS Callback URL" help="Callback URL for this Odoo instance">
                            <field name="ums_callback_url" placeholder="https://odoo.yourserver.com/ums/callback"/>
                        </setting>
                        <setting id="ums_default_groups_setting" string="Default Groups" help="Comma-separated XML IDs for auto-created users">
                            <field name="ums_default_groups" placeholder="base.group_user"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
